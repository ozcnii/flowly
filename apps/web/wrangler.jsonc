{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "flowly-web",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-07-13",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "assets": {
    "binding": "ASSETS",
    "directory": ".open-next/assets"
  },
  "images": {
    "binding": "IMAGES"
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "flowly-web"
    }
  ],
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "flowly-db",
      "database_id": "b9b982f5-120b-47b4-91f4-2945f15796f2",
      "migrations_dir": "../../migrations"
    }
  ],
  "env": {
    "test": {
      "name": "flowly-web-test",
      "images": {
        "binding": "IMAGES"
      },
      "d1_databases": [
        {
          "binding": "DB",
          "database_name": "flowly-db-test",
          "database_id": "fddacf32-9e98-436e-a689-72dc1ae460db",
          "migrations_dir": "../../migrations"
        }
      ],
      "services": [
        {
          "binding": "WORKER_SELF_REFERENCE",
          "service": "flowly-web-test"
        }
      ]
    }
  }
}
