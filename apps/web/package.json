{
  "name": "@flowly/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "cf:build": "opennextjs-cloudflare build",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview --env test",
    "upload:test": "opennextjs-cloudflare build && opennextjs-cloudflare upload --env test",
    "deploy:check": "opennextjs-cloudflare build && wrangler deploy --env test --dry-run --outdir .wrangler/dry-run",
    "deploy:test": "opennextjs-cloudflare build && opennextjs-cloudflare deploy --env test",
    "deploy:production": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env test --env-interface CloudflareEnv --include-runtime false .wrangler/cloudflare-env.d.ts",
    "db:migrate": "wrangler d1 migrations apply flowly-db --local",
    "db:reset": "node scripts/db-reset-local.mjs",
    "db:seed": "wrangler d1 execute flowly-db --local --file=../../seeds/0001_test_users.sql",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@flowly/core": "*",
    "@flowly/database": "*",
    "@flowly/storage": "*",
    "@flowly/telegram": "*",
    "@opennextjs/cloudflare": "1.20.1",
    "@tanstack/react-query": "5.101.2",
    "date-fns": "4.4.0",
    "drizzle-orm": "0.45.2",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.81.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "5.20260713.1",
    "@tailwindcss/postcss": "4.3.2",
    "@types/node": "22.20.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.5",
    "eslint-config-next": "16.2.10",
    "postcss": "8.5.18",
    "tailwindcss": "4.3.2",
    "typescript": "5.9.3",
    "wrangler": "4.110.0"
  }
}
