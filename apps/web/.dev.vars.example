# Copy to .dev.vars for local workerd preview.
NEXTJS_ENV=development

# Telegram bot token (E1-D1-T06). Local dev/test only — use a test bot token.
# Real production token is set as a Cloudflare secret via dashboard/wrangler and
# is never committed. Required by /api/v1/auth/telegram to verify initData.
TELEGRAM_BOT_TOKEN=

# Optional: enable dev-only Telegram user emulation (PRD §10.3) for `next dev`.
# When set to 1, local GET /me creates a mock user session without Telegram.
# NEVER enable in production.
FLOWLY_DEV_EMULATION=

# Optional: Telegram mode (PRD §49.4): mock | test | production.
# Empty = auto: local `next dev` -> mock, deployed -> production.
# Test environment MUST set TELEGRAM_MODE=test explicitly.
# In `mock`, outbound messages are written to a local log and never sent.
TELEGRAM_MODE=

# Optional: Piped API base URL for no-key YouTube search (DEC-049).
# If empty, /api/v1/youtube/search returns the controlled unavailable/stale state.
PIPED_BASE_URL=https://api.piped.private.coffee
