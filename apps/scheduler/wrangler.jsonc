{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "flowly-scheduler",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-13",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "triggers": {
    "crons": ["* * * * *"]
  },
  "env": {
    "test": {
      "name": "flowly-scheduler-test",
      "triggers": {
        "crons": ["* * * * *"]
      }
    }
  }
}
