{
  "name": "flowly",
  "private": true,
  "version": "0.0.0",
  "packageManager": "npm@10.9.8",
  "engines": {
    "node": ">=20.9.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "postcss": "8.5.18"
  },
  "scripts": {
    "dev": "npm run dev --workspace @flowly/web",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "preview": "npm run preview --workspace @flowly/web",
    "test": "npm run test --workspaces --if-present",
    "test:e2e": "npm run test:e2e --workspace @flowly/web --if-present",
    "db:migrate": "npm run db:migrate --workspace @flowly/database --if-present",
    "db:seed": "npm run db:seed --workspace @flowly/database --if-present",
    "db:reset": "npm run db:reset --workspace @flowly/database --if-present",
    "deploy:test": "npm run deploy:test --workspaces --if-present",
    "deploy:production": "npm run deploy:production --workspaces --if-present"
  }
}
